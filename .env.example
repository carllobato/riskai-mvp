# Copy to `.env.local` and fill in values. Never commit `.env.local`.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for “Delete account” in Settings (auth.admin.deleteUser).
# Supabase Dashboard → Project Settings → API → Project API keys → service_role (secret).
# Use this name only ONCE in .env.local — a second empty SUPABASE_SERVICE_ROLE_KEY= line overwrites the value.
SUPABASE_SERVICE_ROLE_KEY=

# Optional (rate limits / caching)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Local only: set to 1 (or true) to open (protected) routes without signing in.
# Use `npm run dev` or local `next start` — not your Vercel URL (VERCEL=1 disables this).
# Restart the dev server after changing. Does not disable Supabase; APIs/data still need a session (RLS).
# DEV_SKIP_AUTH_GUARD=1
